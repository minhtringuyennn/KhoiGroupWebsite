---
interface PubLinks {
  pdf?: string;
  arxiv?: string;
  code?: string;
  project?: string;
}

interface Publication {
  title: string;
  authors: string;
  venue: string;
  year: number;
  links?: PubLinks;
}

interface Props {
  publications: Publication[];
}

const { publications } = Astro.props;

const byYear = publications.reduce(
  (acc, pub) => {
    if (!acc[pub.year]) acc[pub.year] = [];
    acc[pub.year].push(pub);
    return acc;
  },
  {} as Record<number, Publication[]>
);

const years = Object.keys(byYear)
  .map(Number)
  .sort((a, b) => b - a);
---
<div class="space-y-8">
  {years.map(year => (
    <div id={`year-${year}`}>
      <h3 class="text-sm font-semibold text-gray-400 dark:text-gray-600 uppercase tracking-wider mb-3 pb-1 border-b border-gray-100 dark:border-gray-800">{year}</h3>
      <ul class="space-y-4">
        {byYear[year].map(pub => (
          <li class="flex gap-3">
            <div class="w-0.5 bg-primary rounded-full flex-shrink-0 mt-1.5 self-stretch min-h-4"></div>
            <div>
              <p class="font-medium text-gray-900 dark:text-gray-100 text-sm leading-snug">{pub.title}</p>
              <p class="text-xs text-gray-600 dark:text-gray-400 mt-0.5">{pub.authors}</p>
              <p class="text-xs font-semibold text-primary mt-0.5">{pub.venue}</p>
              {pub.links && (
                <div class="flex gap-3 mt-1.5 text-xs font-medium">
                  {pub.links.pdf && (
                    <a href={pub.links.pdf} class="text-primary hover:underline">[PDF]</a>
                  )}
                  {pub.links.arxiv && (
                    <a href={pub.links.arxiv} target="_blank" rel="noopener" class="text-primary hover:underline">[arXiv]</a>
                  )}
                  {pub.links.code && (
                    <a href={pub.links.code} target="_blank" rel="noopener" class="text-primary hover:underline">[Code]</a>
                  )}
                  {pub.links.project && (
                    <a href={pub.links.project} class="text-primary hover:underline">[Project]</a>
                  )}
                </div>
              )}
            </div>
          </li>
        ))}
      </ul>
    </div>
  ))}
</div>
