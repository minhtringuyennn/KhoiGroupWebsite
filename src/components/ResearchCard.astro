---
interface Props {
  title: string;
  description: string;
  image?: string;
  tags?: string[];
}
const { title, description, image, tags = [] } = Astro.props;
---
<div class="border border-gray-200 rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow bg-white">
  {image && (
    <div class="h-36 bg-gradient-to-br from-primary/5 to-primary/10 overflow-hidden">
      <img
        src={image}
        alt={title}
        class="w-full h-full object-cover"
        onerror="this.parentElement.classList.add('flex','items-center','justify-center'); this.style.display='none'"
      />
    </div>
  )}
  <div class="p-4">
    <h3 class="font-semibold text-gray-900 text-sm">{title}</h3>
    <p class="text-xs text-gray-600 mt-1.5 leading-relaxed">{description}</p>
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5 mt-3">
        {tags.map(tag => (
          <span class="px-2 py-0.5 text-xs bg-primary/5 text-primary rounded-full border border-primary/15">
            {tag}
          </span>
        ))}
      </div>
    )}
  </div>
</div>
