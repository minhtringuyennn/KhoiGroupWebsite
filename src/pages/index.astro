---
import Layout from '../layouts/Layout.astro';
import { readFileSync } from 'fs';
import yaml from 'js-yaml';
import { join } from 'path';

const dataDir = join(process.cwd(), 'src/data');
function loadYaml(file: string) {
  return yaml.load(readFileSync(join(dataDir, file), 'utf-8'));
}

const group = loadYaml('group.yaml') as any;
const news  = loadYaml('news.yaml')  as any[];

const byYear: Record<number, any[]> = {};
for (const item of news) {
  if (!byYear[item.year]) byYear[item.year] = [];
  byYear[item.year].push(item);
}
const years = Object.keys(byYear).map(Number).sort((a, b) => b - a);

const categories: any[] = group.news_categories ?? [];
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const heroLinks: any[]  = (group.hero_links ?? []).map((l: any) => ({
  ...l,
  href: l.href?.startsWith('/') ? `${base}${l.href}` : l.href,
}));
---
<Layout title={group.name} description={group.tagline} active="home">

  <div class="relative w-full bg-gray-900 overflow-hidden flex items-center min-h-64 sm:min-h-72">
    <div class="absolute inset-0 bg-gradient-to-r from-gray-900/95 via-gray-900/80 to-gray-900/40"></div>
    <div class="relative z-10 max-w-5xl mx-auto px-6 py-14 w-full">
      <div class="max-w-xl">
        <p class="text-gray-400 text-xs sm:text-sm tracking-widest uppercase mb-2">
          {group.department} · {group.institution}
        </p>
        <h1 class="text-3xl sm:text-4xl font-bold text-white leading-tight mb-3">{group.name}</h1>
        <p class="text-gray-300 text-sm sm:text-base leading-relaxed">{group.tagline}</p>
        <div class="flex flex-wrap gap-3 mt-6">
          {heroLinks.map((link: any) => (
            <a
              href={link.href}
              class={link.variant === 'primary'
                ? 'px-4 py-2 bg-primary text-white text-sm font-medium hover:bg-accent transition-colors duration-150'
                : 'px-4 py-2 border border-white/40 text-white text-sm font-medium hover:border-white transition-colors duration-150'}
            >
              {link.label}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-10">

    <section class="mb-10">
      <h2 class="text-xl font-semibold text-gray-900 dark:text-gray-100 mb-6">Recent News</h2>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 sm:gap-4">
        {categories.map((cat: any) => (
          <button
            data-filter={cat.key}
            class="filter-btn flex flex-col items-center gap-2 p-4 sm:p-5 border-2 border-gray-200 dark:border-gray-800 rounded-lg transition-all duration-200 text-center cursor-pointer w-full hover:border-primary hover:shadow-sm bg-white dark:bg-gray-900"
          >
            <span class={`${cat.icon} w-6 h-6 sm:w-7 sm:h-7 btn-icon text-gray-400 dark:text-gray-600 transition-colors duration-200`}></span>
            <span class="text-xs sm:text-sm font-medium text-gray-700 dark:text-gray-300 btn-label transition-colors duration-200">
              {cat.label}
            </span>
            <span class="text-xs text-primary font-semibold">More ▶</span>
          </button>
        ))}
      </div>
    </section>

    <section id="timeline-section">
      <div class="flex items-center gap-0 mb-8">
        <div class="flex-1 h-px bg-gray-200 dark:bg-gray-800"></div>
        <h2 id="timeline-label" class="px-4 text-xs font-bold text-gray-400 dark:text-gray-600 uppercase tracking-widest transition-all duration-200">
          News Timeline
        </h2>
        <div class="flex-1 h-px bg-gray-200 dark:bg-gray-800"></div>
      </div>

      <div class="space-y-10" id="timeline">
        {years.map(year => (
          <div class="year-group" data-year={year}>
            <h3 class="text-xl sm:text-2xl font-bold text-gray-900 dark:text-gray-100 mb-6">{year}</h3>
            <div class="space-y-5 sm:space-y-6">
              {byYear[year].map((item: any) => (
                <div class="news-entry flex gap-3 sm:gap-6" data-category={item.category}>
                  <div class="w-20 sm:w-28 flex-shrink-0 text-right pt-0.5">
                    <span class="text-xs sm:text-sm font-mono text-gray-400 dark:text-gray-500 leading-snug">{item.date}</span>
                  </div>
                  <div class="flex-shrink-0 w-px bg-gray-200 dark:bg-gray-700 relative self-stretch">
                    <div class="absolute top-2 -left-1 w-2 h-2 rounded-full bg-gray-300 dark:bg-gray-600"></div>
                  </div>
                  <ul class="flex-1 pb-2 space-y-1 min-w-0">
                    {item.items.map((text: string) => (
                      <li class="text-sm text-gray-700 dark:text-gray-300 flex gap-2 leading-relaxed">
                        <span class="text-gray-400 dark:text-gray-500 flex-shrink-0 mt-0.5">•</span>
                        <span>{text}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

  </div>
</Layout>

<script>
  function initFilter() {
    const buttons    = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const entries    = document.querySelectorAll<HTMLElement>('.news-entry');
    const yearGroups = document.querySelectorAll<HTMLElement>('.year-group');
    const label      = document.getElementById('timeline-label')!;
    const section    = document.getElementById('timeline-section')!;

    let active: string | null = null;

    function applyFilter(key: string | null, animate = true) {
      active = key;

      buttons.forEach(btn => {
        const on = btn.dataset.filter === key;
        btn.classList.toggle('border-primary', on);
        btn.classList.toggle('shadow-sm', on);
        const icon = btn.querySelector<HTMLElement>('.btn-icon');
        const lbl  = btn.querySelector<HTMLElement>('.btn-label');
        if (icon) {
          icon.classList.toggle('text-primary',       on);
          icon.classList.toggle('text-gray-400',      !on);
          icon.classList.toggle('dark:text-gray-600', !on);
        }
        if (lbl) {
          lbl.classList.toggle('text-primary',        on);
          lbl.classList.toggle('text-gray-700',       !on);
          lbl.classList.toggle('dark:text-gray-300',  !on);
        }
      });

      entries.forEach(entry => {
        const show = key === null || entry.dataset.category === key;
        if (show) {
          entry.style.removeProperty('display');
          if (animate) {
            entry.style.opacity = '0';
            entry.style.transition = 'none';
            requestAnimationFrame(() => {
              entry.style.transition = 'opacity 200ms ease';
              entry.style.opacity = '1';
            });
          } else {
            entry.style.removeProperty('opacity');
            entry.style.removeProperty('transition');
          }
        } else {
          entry.style.display = 'none';
          entry.style.removeProperty('opacity');
          entry.style.removeProperty('transition');
        }
      });

      yearGroups.forEach(group => {
        const hasVisible = Array.from(group.querySelectorAll<HTMLElement>('.news-entry'))
          .some(e => e.style.display !== 'none');
        group.style.display = hasVisible ? '' : 'none';
      });

      const cat = key ? key.charAt(0).toUpperCase() + key.slice(1) : null;
      label.textContent = cat ? `${cat} News` : 'News Timeline';

      if (key && animate) {
        setTimeout(() => section.scrollIntoView({ behavior: 'smooth', block: 'start' }), 50);
      }
    }

    applyFilter(null, false);

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        applyFilter(active === btn.dataset.filter ? null : btn.dataset.filter!);
      });
    });
  }

  initFilter();
  document.addEventListener('astro:after-swap', initFilter);
</script>
