---
import Layout from '../layouts/Layout.astro';
import { readFileSync } from 'fs';
import { join as pathJoin } from 'path';

function md2html(md: string): string {
  return md
    .replace(/^### (.+)$/gm, '<h3 class="text-base font-bold text-gray-900 mt-6 mb-2">$1</h3>')
    .replace(/^## (.+)$/gm, '<h2 class="text-xl font-bold text-gray-900 mt-8 mb-3 pb-1 border-b border-gray-200">$1</h2>')
    .replace(/^# (.+)$/gm, '<h1 class="text-2xl font-bold text-gray-900 mb-6">$1</h1>')
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" class="text-primary hover:underline">$1</a>')
    .replace(/^---$/gm, '<hr class="border-gray-200 my-8" />')
    .replace(/^\d+\. (.+)$/gm, '<li class="ml-5 list-decimal text-gray-700">$1</li>')
    .replace(/^- (.+)$/gm, '<li class="ml-5 list-disc text-gray-700">$1</li>')
    .split('\n')
    .map(line => {
      const trimmed = line.trim();
      if (!trimmed) return '<br>';
      if (trimmed.startsWith('<')) return line;
      return `<p class="text-gray-700 leading-relaxed">${trimmed}</p>`;
    })
    .join('\n');
}

const rawMd = readFileSync(pathJoin(process.cwd(), 'src/content/join.md'), 'utf-8');
const html = md2html(rawMd);
---
<Layout title="Join Us — MLR Lab" active="join">
  <div class="max-w-3xl mx-auto px-4 py-10">
    <div class="space-y-1 text-sm" set:html={html} />
  </div>
</Layout>
