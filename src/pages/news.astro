---
import Layout from '../layouts/Layout.astro';
import NewsItem from '../components/NewsItem.astro';
import { readFileSync } from 'fs';
import yaml from 'js-yaml';
import { join } from 'path';

const news = yaml.load(
  readFileSync(join(process.cwd(), 'src/data/news.yaml'), 'utf-8')
) as any[];
---
<Layout title="News — MLR Lab" active="news">
  <div class="max-w-6xl mx-auto px-4 py-10">
    <h1 class="text-2xl font-bold text-gray-900 mb-8">News</h1>
    <ul class="space-y-3">
      {news.map((item: any) => (
        <NewsItem date={item.date} text={item.text} />
      ))}
    </ul>
  </div>
</Layout>
