---
import Layout from '../layouts/Layout.astro';
import { readFileSync } from 'fs';
import yaml from 'js-yaml';
import { join } from 'path';

const dataDir = join(process.cwd(), 'src/data');
function loadYaml(file: string) {
  return yaml.load(readFileSync(join(dataDir, file), 'utf-8'));
}

const pagesConfig = loadYaml('pages.yaml') as Record<string, boolean>;
if (pagesConfig.opening === false) return Astro.redirect('/');

const group   = loadYaml('group.yaml')   as any;
const opening = loadYaml('opening.yaml') as any;

const atAGlance: string[] = opening.at_a_glance ?? [];
const expectations: any[] = opening.expectations ?? [];
const provisions: any[]   = opening.provisions   ?? [];
const aboutInst           = opening.about_institution ?? {};
const institutes: any[]   = opening.institutes ?? [];
---
<Layout title="Opening — MLR Lab" active="opening">

  <div class="relative w-full h-56 sm:h-72 bg-gray-800 dark:bg-gray-900 overflow-hidden flex items-end">
    <div class="absolute inset-0 bg-gradient-to-t from-gray-900/90 via-gray-900/50 to-gray-900/20"></div>
    <div class="relative z-10 max-w-5xl mx-auto px-6 w-full pb-10">
      <h1 class="text-3xl sm:text-4xl font-bold text-white mb-2">Opening</h1>
      <p class="text-gray-300 text-sm sm:text-base max-w-xl">
        {group.name} always welcomes exceptional PhD candidates and researchers in AI/ML.
      </p>
    </div>
  </div>

  <div class="max-w-5xl mx-auto px-6 py-12 space-y-14">

    <section class="flex flex-col sm:flex-row gap-8 items-start">
      <div class="flex-1">
        <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-5">
          {group.name} — At-a-Glance
        </h2>
        <ul class="space-y-2.5">
          {atAGlance.map((item: string) => (
            <li class="flex gap-3 text-sm text-gray-700 dark:text-gray-300">
              <span class="text-primary flex-shrink-0 mt-0.5">•</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="flex-shrink-0 w-40 sm:w-44 mx-auto sm:mx-0">
        <div class="border-4 border-gray-900 dark:border-gray-100 p-3 text-center bg-amber-50 dark:bg-amber-900/20 rounded-sm shadow-md">
          <p class="text-xs font-black tracking-widest uppercase text-gray-900 dark:text-gray-100 border-b-2 border-gray-900 dark:border-gray-100 pb-1 mb-2">WANTED</p>
          <div class="w-full h-20 bg-gray-300 dark:bg-gray-700 mb-2 flex items-center justify-center rounded-sm">
            <span class="i-ph-user-bold w-10 h-10 text-gray-400 dark:text-gray-600"></span>
          </div>
          <p class="text-xs font-black uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-1">Dead or Alive</p>
          <p class="text-sm font-black uppercase tracking-widest text-primary leading-tight">YOUR<br/>NAME</p>
          <p class="text-xs text-gray-500 dark:text-gray-400 mt-2 italic">Top PhD Candidate</p>
        </div>
      </div>
    </section>

    <section>
      <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100 text-center mb-1">
        What do we expect from good candidates?
      </h2>
      <div class="flex justify-center mb-6"><div class="w-8 h-0.5 bg-primary"></div></div>
      <div class="space-y-2 max-w-3xl mx-auto">
        {expectations.map((item: any) => (
          <details class="group border border-gray-200 dark:border-gray-800 rounded overflow-hidden bg-white dark:bg-gray-900">
            <summary class="flex items-center justify-between gap-3 px-5 py-3.5 cursor-pointer select-none text-sm font-medium text-gray-800 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors list-none">
              <span class="flex items-start gap-2">
                <span class="i-ph-check-circle-bold w-4 h-4 text-primary flex-shrink-0 mt-0.5"></span>
                {item.q}
              </span>
              <span class="i-ph-caret-down-bold w-4 h-4 text-gray-400 flex-shrink-0 transition-transform duration-200 group-open:rotate-180"></span>
            </summary>
            <div class="px-5 pb-4 pt-1 text-sm text-gray-600 dark:text-gray-400 leading-relaxed border-t border-gray-100 dark:border-gray-800">
              {item.a}
            </div>
          </details>
        ))}
      </div>
    </section>

    <section>
      <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100 text-center mb-1">
        What we provide to our students?
      </h2>
      <div class="flex justify-center mb-6"><div class="w-8 h-0.5 bg-primary"></div></div>
      <div class="space-y-2 max-w-3xl mx-auto">
        {provisions.map((item: any) => (
          <details class="group border border-gray-200 dark:border-gray-800 rounded overflow-hidden bg-white dark:bg-gray-900">
            <summary class="flex items-center justify-between gap-3 px-5 py-3.5 cursor-pointer select-none text-sm font-medium text-gray-800 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors list-none">
              <span class="flex items-start gap-2">
                <span class="i-ph-star-bold w-4 h-4 text-primary flex-shrink-0 mt-0.5"></span>
                {item.q}
              </span>
              <span class="i-ph-caret-down-bold w-4 h-4 text-gray-400 flex-shrink-0 transition-transform duration-200 group-open:rotate-180"></span>
            </summary>
            <div class="px-5 pb-4 pt-1 text-sm text-gray-600 dark:text-gray-400 leading-relaxed border-t border-gray-100 dark:border-gray-800">
              {item.a}
            </div>
          </details>
        ))}
      </div>
    </section>

    <section class="flex flex-col sm:flex-row gap-8 items-start">
      <div class="w-full sm:w-64 flex-shrink-0 h-40 bg-gray-200 dark:bg-gray-800 rounded overflow-hidden flex items-center justify-center">
        <span class="i-ph-buildings-bold w-12 h-12 text-gray-400 dark:text-gray-600"></span>
      </div>
      <div>
        <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-3">{aboutInst.title}</h2>
        <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed mb-3">{aboutInst.description}</p>
        <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">{aboutInst.detail}</p>
      </div>
    </section>

    <section>
      <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100 text-center mb-1">AI/ML at CMU</h2>
      <div class="flex justify-center mb-6"><div class="w-8 h-0.5 bg-primary"></div></div>
      <div class="space-y-3 max-w-3xl mx-auto">
        {institutes.map((inst: any) => (
          <div class="flex items-center gap-4 p-4 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded">
            <span class="i-ph-buildings-bold w-5 h-5 text-primary flex-shrink-0"></span>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-semibold text-gray-800 dark:text-gray-200">{inst.name}</p>
              <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">{inst.desc}</p>
            </div>
            <a href={inst.href} class="text-xs font-semibold text-primary hover:underline flex-shrink-0">Learn More →</a>
          </div>
        ))}
      </div>
    </section>

    <section class="max-w-2xl mx-auto">
      <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100 text-center mb-1">How to Apply</h2>
      <div class="flex justify-center mb-6"><div class="w-8 h-0.5 bg-primary"></div></div>
      <div class="p-6 sm:p-8 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded space-y-4">
        <div>
          <p class="text-sm font-semibold text-gray-900 dark:text-gray-100 mb-1">PhD Applications</p>
          <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
            Apply through the <strong class="text-gray-800 dark:text-gray-200">CMU School of Computer Science PhD program</strong> and
            mention Prof. Smith's name in your application. Read our recent papers to confirm research alignment.
          </p>
        </div>
        <div>
          <p class="text-sm font-semibold text-gray-900 dark:text-gray-100 mb-1">Email Inquiries</p>
          <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
            Email <a href={`mailto:${group.contact_email}`} class="text-primary hover:underline">{group.contact_email}</a> with
            subject line <strong class="text-gray-800 dark:text-gray-200">"[Position] — Your Name"</strong> and include
            your CV, a brief research statement, and 1–2 representative papers.
          </p>
        </div>
        <p class="text-xs text-gray-400 dark:text-gray-600 italic">
          Due to high email volume, we may not be able to respond to all inquiries.
        </p>
      </div>
    </section>

    <section class="max-w-xl mx-auto">
      <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100 text-center mb-1">Sign me up!</h2>
      <div class="flex justify-center mb-6"><div class="w-8 h-0.5 bg-primary"></div></div>
      <p class="text-sm text-gray-500 dark:text-gray-400 text-center mb-6">
        Subscribe to receive updates about lab openings and research opportunities.
      </p>
      <form class="space-y-3" onsubmit="event.preventDefault()">
        <div class="flex gap-3">
          <input type="text" placeholder="First Name"
            class="flex-1 px-4 py-2.5 text-sm border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 rounded focus:outline-none focus:border-primary transition-colors" />
          <input type="text" placeholder="Last Name"
            class="flex-1 px-4 py-2.5 text-sm border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 rounded focus:outline-none focus:border-primary transition-colors" />
        </div>
        <input type="email" placeholder="Email"
          class="w-full px-4 py-2.5 text-sm border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 rounded focus:outline-none focus:border-primary transition-colors" />
        <textarea placeholder="Message (optional)" rows={3}
          class="w-full px-4 py-2.5 text-sm border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 rounded focus:outline-none focus:border-primary transition-colors resize-none"></textarea>
        <div class="text-center">
          <button type="submit"
            class="px-8 py-2.5 bg-primary text-white text-sm font-semibold hover:bg-accent transition-colors duration-150 rounded">
            Subscribe
          </button>
        </div>
      </form>
    </section>

  </div>
</Layout>
