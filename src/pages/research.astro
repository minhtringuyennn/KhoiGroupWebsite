---
import Layout from '../layouts/Layout.astro';
import { readFileSync } from 'fs';
import yaml from 'js-yaml';
import { join } from 'path';

const research = yaml.load(
  readFileSync(join(process.cwd(), 'src/data/research.yaml'), 'utf-8')
) as any;

const overview: string[] = research.overview ?? [];
const areas: any[]       = research.areas ?? [];
---
<Layout title="Research — MLR Lab" active="research">
  <div class="max-w-5xl mx-auto px-6 py-12">

    <h1 class="text-3xl font-bold text-gray-800 dark:text-gray-100 mb-2">
      Research Overview <span class="text-gray-400 dark:text-gray-600 font-normal text-2xl">— by PI</span>
    </h1>

    <div class="mt-8 space-y-5 text-base text-gray-700 dark:text-gray-300 leading-relaxed max-w-3xl">
      {overview.map((para: string, i: number) => (
        i === overview.length - 1
          ? <p><strong class="text-gray-900 dark:text-gray-100">{para}</strong></p>
          : <p>{para}</p>
      ))}
    </div>

    <div class="mt-14 grid grid-cols-1 md:grid-cols-2 gap-8">
      {areas.map((r: any) => (
        <div class="border-t-2 border-primary pt-5">
          <h3 class="text-lg font-bold text-gray-900 dark:text-gray-100 mb-2">{r.title}</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed mb-3">{r.description}</p>
          {r.tags && r.tags.length > 0 && (
            <div class="flex flex-wrap gap-1.5">
              {r.tags.map((tag: string) => (
                <span class="px-2 py-0.5 text-xs border border-gray-300 dark:border-gray-700 text-gray-500 dark:text-gray-400 rounded">
                  {tag}
                </span>
              ))}
            </div>
          )}
        </div>
      ))}
    </div>

  </div>
</Layout>
