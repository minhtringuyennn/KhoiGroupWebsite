---
import Layout from '../layouts/Layout.astro';
import { readFileSync } from 'fs';
import yaml from 'js-yaml';
import { join } from 'path';

const dataDir = join(process.cwd(), 'src/data');
function loadYaml(file: string) {
  return yaml.load(readFileSync(join(dataDir, file), 'utf-8'));
}

const members = loadYaml('members.yaml') as any[];
const group   = loadYaml('group.yaml')   as any;

const pi        = members.find((m: any) => m.category === 'pi');
const postdocs  = members.filter((m: any) => m.status === 'current' && m.category === 'postdoc');
const phds      = members.filter((m: any) => m.status === 'current' && m.category === 'phd');
const ms        = members.filter((m: any) => m.status === 'current' && m.category === 'ms');
const undergrads= members.filter((m: any) => m.status === 'current' && m.category === 'undergrad');
const alumni    = members.filter((m: any) => m.status === 'alumni');

const stats: string[] = (group.team_stats ?? []).map((s: any) => `${s.value} ${s.label}`);
---
<Layout title="Team — MLR Lab" active="team">

  <div class="max-w-3xl mx-auto px-6 pt-14 pb-10 text-center">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-50 mb-5">About Us</h1>
    <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed mb-6 max-w-2xl mx-auto">
      The PI is most proud of being surrounded by some of the world's most brilliant students.
      Our Ph.D. students have won prestigious fellowships, best paper awards, and competition prizes,
      and alumni have gone on to top academic and industry positions.
    </p>
    <ul class="text-sm text-gray-700 dark:text-gray-300 space-y-2 inline-block text-left">
      {stats.map(s => (
        <li class="flex items-start gap-2">
          <span class="i-ph-check-circle-bold w-4 h-4 text-primary flex-shrink-0 mt-0.5"></span>
          <span>{s}</span>
        </li>
      ))}
    </ul>
  </div>

  <div class="w-full h-56 sm:h-72 bg-gray-800 dark:bg-gray-900 overflow-hidden relative flex items-center justify-center">
    <span class="text-gray-600 dark:text-gray-700 text-sm italic select-none">[ Group Photo ]</span>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent to-black/20"></div>
  </div>

  {pi && (
    <div class="max-w-4xl mx-auto px-6 py-12">
      <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100 text-center mb-8">
        Principal Investigator
      </h2>
      <div class="flex flex-col sm:flex-row gap-6 items-start bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded p-6 max-w-2xl mx-auto">
        <div class="w-28 h-28 rounded overflow-hidden bg-gray-200 dark:bg-gray-700 flex-shrink-0 mx-auto sm:mx-0 flex items-center justify-center">
          <img
            src={pi.photo}
            alt={pi.name}
            class="w-full h-full object-cover"
            onerror={`this.style.display='none';this.parentElement.innerHTML='<span class="text-3xl font-bold text-gray-400">${pi.name[0]}</span>'`}
          />
        </div>
        <div class="flex-1 min-w-0 text-center sm:text-left">
          <h3 class="font-bold text-gray-900 dark:text-gray-100 text-lg">{pi.name}</h3>
          <p class="text-sm text-primary mb-3">{pi.role}</p>
          <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed mb-4">{pi.bio}</p>
          <div class="flex gap-4 text-xs flex-wrap justify-center sm:justify-start">
            {pi.links?.website && <a href={pi.links.website} target="_blank" rel="noopener" class="text-primary hover:underline">Website</a>}
            {pi.links?.scholar && <a href={pi.links.scholar} target="_blank" rel="noopener" class="text-primary hover:underline">Scholar</a>}
            {pi.links?.github  && <a href={pi.links.github}  target="_blank" rel="noopener" class="text-primary hover:underline">GitHub</a>}
            {pi.links?.email   && <a href={`mailto:${pi.links.email}`} class="text-primary hover:underline">Email</a>}
          </div>
        </div>
      </div>
    </div>
  )}

  <div class="border-t border-gray-100 dark:border-gray-800 bg-gray-50 dark:bg-gray-900/40">
    <div class="max-w-5xl mx-auto px-6 py-14">
      <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100 text-center mb-12">Meet The Team</h2>

      {postdocs.length > 0 && (
        <div class="mb-12">
          <h3 class="text-xs font-bold text-gray-400 dark:text-gray-600 uppercase tracking-widest text-center mb-8 pb-2 border-b border-gray-200 dark:border-gray-800">
            Postdoctoral Researchers
          </h3>
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-6">
            {postdocs.map((m: any) => (
              <div class="flex flex-col items-center text-center">
                <div class="w-24 h-24 sm:w-28 sm:h-28 rounded-full overflow-hidden bg-gray-200 dark:bg-gray-700 mb-3 flex items-center justify-center">
                  <img src={m.photo} alt={m.name} class="w-full h-full object-cover"
                    onerror={`this.style.display='none';this.parentElement.innerHTML='<span class="text-2xl font-bold text-gray-400">${m.name[0]}</span>'`} />
                </div>
                <h4 class="font-semibold text-sm text-gray-900 dark:text-gray-100 leading-snug">{m.name}</h4>
                <p class="text-xs text-primary mt-0.5 leading-snug">{m.role}</p>
                <div class="flex gap-2 mt-1.5 text-xs flex-wrap justify-center">
                  {m.links?.website && <a href={m.links.website} target="_blank" rel="noopener" class="text-gray-400 hover:text-primary transition-colors">Web</a>}
                  {m.links?.scholar && <a href={m.links.scholar} target="_blank" rel="noopener" class="text-gray-400 hover:text-primary transition-colors">Scholar</a>}
                  {m.links?.github  && <a href={m.links.github}  target="_blank" rel="noopener" class="text-gray-400 hover:text-primary transition-colors">GitHub</a>}
                  {m.links?.email   && <a href={`mailto:${m.links.email}`} class="text-gray-400 hover:text-primary transition-colors">Email</a>}
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

      {phds.length > 0 && (
        <div class="mb-12">
          <h3 class="text-xs font-bold text-gray-400 dark:text-gray-600 uppercase tracking-widest text-center mb-8 pb-2 border-b border-gray-200 dark:border-gray-800">
            Ph.D. Students
          </h3>
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-6">
            {phds.map((m: any) => (
              <div class="flex flex-col items-center text-center">
                <div class="w-24 h-24 sm:w-28 sm:h-28 rounded-full overflow-hidden bg-gray-200 dark:bg-gray-700 mb-3 flex items-center justify-center">
                  <img src={m.photo} alt={m.name} class="w-full h-full object-cover"
                    onerror={`this.style.display='none';this.parentElement.innerHTML='<span class="text-2xl font-bold text-gray-400">${m.name[0]}</span>'`} />
                </div>
                <h4 class="font-semibold text-sm text-gray-900 dark:text-gray-100 leading-snug">{m.name}</h4>
                <p class="text-xs text-primary mt-0.5 leading-snug">{m.role}</p>
                <div class="flex gap-2 mt-1.5 text-xs flex-wrap justify-center">
                  {m.links?.website && <a href={m.links.website} target="_blank" rel="noopener" class="text-gray-400 hover:text-primary transition-colors">Web</a>}
                  {m.links?.scholar && <a href={m.links.scholar} target="_blank" rel="noopener" class="text-gray-400 hover:text-primary transition-colors">Scholar</a>}
                  {m.links?.github  && <a href={m.links.github}  target="_blank" rel="noopener" class="text-gray-400 hover:text-primary transition-colors">GitHub</a>}
                  {m.links?.email   && <a href={`mailto:${m.links.email}`} class="text-gray-400 hover:text-primary transition-colors">Email</a>}
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

      {ms.length > 0 && (
        <div class="mb-12">
          <h3 class="text-xs font-bold text-gray-400 dark:text-gray-600 uppercase tracking-widest text-center mb-8 pb-2 border-b border-gray-200 dark:border-gray-800">
            M.S. Students
          </h3>
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-6">
            {ms.map((m: any) => (
              <div class="flex flex-col items-center text-center">
                <div class="w-24 h-24 sm:w-28 sm:h-28 rounded-full overflow-hidden bg-gray-200 dark:bg-gray-700 mb-3 flex items-center justify-center">
                  <img src={m.photo} alt={m.name} class="w-full h-full object-cover"
                    onerror={`this.style.display='none';this.parentElement.innerHTML='<span class="text-2xl font-bold text-gray-400">${m.name[0]}</span>'`} />
                </div>
                <h4 class="font-semibold text-sm text-gray-900 dark:text-gray-100 leading-snug">{m.name}</h4>
                <p class="text-xs text-primary mt-0.5 leading-snug">{m.role}</p>
                <div class="flex gap-2 mt-1.5 text-xs flex-wrap justify-center">
                  {m.links?.website && <a href={m.links.website} target="_blank" rel="noopener" class="text-gray-400 hover:text-primary transition-colors">Web</a>}
                  {m.links?.scholar && <a href={m.links.scholar} target="_blank" rel="noopener" class="text-gray-400 hover:text-primary transition-colors">Scholar</a>}
                  {m.links?.github  && <a href={m.links.github}  target="_blank" rel="noopener" class="text-gray-400 hover:text-primary transition-colors">GitHub</a>}
                  {m.links?.linkedin && <a href={m.links.linkedin} target="_blank" rel="noopener" class="text-gray-400 hover:text-primary transition-colors">LinkedIn</a>}
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

      {undergrads.length > 0 && (
        <div class="mb-12">
          <h3 class="text-xs font-bold text-gray-400 dark:text-gray-600 uppercase tracking-widest text-center mb-8 pb-2 border-b border-gray-200 dark:border-gray-800">
            Undergraduate Students
          </h3>
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-6">
            {undergrads.map((m: any) => (
              <div class="flex flex-col items-center text-center">
                <div class="w-24 h-24 sm:w-28 sm:h-28 rounded-full overflow-hidden bg-gray-200 dark:bg-gray-700 mb-3 flex items-center justify-center">
                  <img src={m.photo} alt={m.name} class="w-full h-full object-cover"
                    onerror={`this.style.display='none';this.parentElement.innerHTML='<span class="text-2xl font-bold text-gray-400">${m.name[0]}</span>'`} />
                </div>
                <h4 class="font-semibold text-sm text-gray-900 dark:text-gray-100 leading-snug">{m.name}</h4>
                <p class="text-xs text-primary mt-0.5 leading-snug">{m.role}</p>
              </div>
            ))}
          </div>
        </div>
      )}

      {alumni.length > 0 && (
        <div>
          <h3 class="text-xs font-bold text-gray-400 dark:text-gray-600 uppercase tracking-widest text-center mb-2 pb-2 border-b border-gray-200 dark:border-gray-800">
            Alumni
          </h3>
          <p class="text-xs text-gray-400 dark:text-gray-600 text-center mb-6 italic">
            Ph.D. Students / Postdocs → Academia &amp; Industry
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 max-w-3xl mx-auto">
            {alumni.map((m: any) => (
              <div class="flex items-center gap-3 py-3 px-4 bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded">
                <div class="w-10 h-10 rounded-full overflow-hidden bg-gray-200 dark:bg-gray-700 flex-shrink-0 flex items-center justify-center">
                  <img src={m.photo} alt={m.name} class="w-full h-full object-cover"
                    onerror={`this.style.display='none';this.parentElement.innerHTML='<span class="text-sm font-bold text-gray-400">${m.name[0]}</span>'`} />
                </div>
                <div class="flex-1 min-w-0">
                  <p class="text-sm font-medium text-gray-800 dark:text-gray-200 truncate">{m.name}</p>
                  {m.current_position && (
                    <p class="text-xs text-gray-400 dark:text-gray-600 truncate">→ {m.current_position}</p>
                  )}
                </div>
                {m.links?.website && (
                  <a href={m.links.website} target="_blank" rel="noopener" class="text-xs text-primary hover:underline flex-shrink-0">Web</a>
                )}
              </div>
            ))}
          </div>
        </div>
      )}

    </div>
  </div>

</Layout>
